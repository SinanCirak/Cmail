# Copy to .env.local and fill in real values (never commit .env.local).

VITE_COGNITO_REGION=ca-central-1
VITE_COGNITO_DOMAIN=https://your-cognito-domain.example.com
VITE_COGNITO_CLIENT_ID=replace_with_client_id
VITE_COGNITO_REDIRECT_URI=https://your-site.example.com/
VITE_COGNITO_LOGOUT_URI=https://your-site.example.com/
VITE_MAIL_API_URL=https://your-api-id.execute-api.region.amazonaws.com/prod/mail
